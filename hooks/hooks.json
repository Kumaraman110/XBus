{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/channel/session-start-hook.js\"" },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/channel/rewaker-entry.js\"", "async": true, "asyncRewake": true, "timeout": 1800 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/channel/hook-entry.js\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/channel/hook-entry.js\"" }
        ]
      }
    ]
  }
}
